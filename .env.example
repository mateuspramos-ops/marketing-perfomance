# URL do CSV publicado da planilha Google Sheets com os dados de performance.
# Deixe em branco durante o desenvolvimento para usar os dados de demonstração.
# Veja instruções de como gerar essa URL no README.md.
GOOGLE_SHEET_CSV_URL=

# Overrides opcionais para as abas de Clientes/Produtividade, caso o gid delas
# seja diferente do que é derivado automaticamente de GOOGLE_SHEET_CSV_URL.
GOOGLE_SHEET_CLIENTS_CSV_URL=

# Credenciais de Meta Ads e Google Ads (página /campanhas). Enquanto vazias,
# a página roda com dados de demonstração. Ver README.md para como obtê-las.
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
